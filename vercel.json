{
  "version": 2,
  "buildCommand": "echo No build step required",
  "builds": [
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/assets/products\\.json",
      "dest": "/backend/frontend/assets/products.json",
      "headers": {
        "Cache-Control": "public, max-age=300, s-maxage=1800, stale-while-revalidate=3600"
      }
    },
    {
      "src": "/assets/(.*)",
      "dest": "/backend/frontend/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, s-maxage=31536000, immutable"
      }
    },
    {
      "src": "/images/(.*)",
      "dest": "/backend/frontend/images/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, s-maxage=31536000, immutable"
      }
    },
    {
      "src": "/all-products_files/(.*)",
      "dest": "/backend/frontend/all-products_files/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, s-maxage=31536000, immutable"
      }
    },
    {
      "src": "/product/(.*)",
      "status": 308,
      "headers": { "Location": "/products.html" }
    },
    {
      "src": "/category/(.*)",
      "status": 308,
      "headers": { "Location": "/" }
    },
    {
      "src": "/(.*)",
      "dest": "backend/api/index.py"
    }
  ]
}
